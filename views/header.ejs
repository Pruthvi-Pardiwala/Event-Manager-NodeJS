<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Stubhouse — Events worth showing up for</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Stubhouse is where small, independent events get listed, sold, and shown up for.">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Work+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/assets/css/theme.css">
</head>
<body>

<header class="site-header">
    <div class="nav-row">
        <a href="/" class="brand">
            <svg class="brand-mark" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="24" cy="24" r="22" fill="none" stroke="#ffb627" stroke-width="1.5" stroke-dasharray="3 4"/>
                <g transform="rotate(-8 24 24)">
                    <rect x="11" y="17" width="26" height="14" rx="3" fill="#ffb627"/>
                    <circle cx="24" cy="17" r="3" fill="#14132b"/>
                    <circle cx="24" cy="31" r="3" fill="#14132b"/>
                </g>
            </svg>
            <span class="brand-word">Stub<span>house</span></span>
        </a>

        <button class="nav-toggle" data-nav-toggle aria-expanded="false" aria-controls="main-nav" aria-label="Toggle menu">
            <span></span>
        </button>

        <nav class="main-nav" id="main-nav">
            <ul>
                <li><a href="/" <%- (typeof activeNav !== 'undefined' && activeNav === 'home') ? 'aria-current="page"' : '' %>>Home</a></li>
                <li><a href="/view-event" <%- (typeof activeNav !== 'undefined' && activeNav === 'view') ? 'aria-current="page"' : '' %>>Events</a></li>
                <li><a href="/add-event" <%- (typeof activeNav !== 'undefined' && activeNav === 'add') ? 'aria-current="page"' : '' %>>Host</a></li>
                <li><a href="/contact" <%- (typeof activeNav !== 'undefined' && activeNav === 'contact') ? 'aria-current="page"' : '' %>>Contact</a></li>
            </ul>

            <div class="nav-actions">
                <a href="/add-event" class="btn btn-primary btn-sm">List an event</a>
            </div>
        </nav>
    </div>
</header>
