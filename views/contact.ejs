<%- include('header', { activeNav: 'contact' }) %>

<section class="section">
    <div class="wrap">
        <div class="section-head">
            <div>
                <span class="eyebrow">Get in touch</span>
                <h2>Questions about a listing?</h2>
                <p>Whether you're hosting your first event or chasing down a ticket, send a note and we'll get back to you.</p>
            </div>
        </div>

        <div class="contact-grid">
            <div class="contact-info-card">
                <h2>Reach the box office</h2>
                <ul class="contact-list">
                    <li>
                        <svg viewBox="0 0 24 24"><path d="M3 7l9 6 9-6M5 5h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span><a href="mailto:hello@stubhouse.events">hello@stubhouse.events</a></span>
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.68 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.32 1.85.55 2.81.68A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span><a href="tel:+15551234567">+1 (555) 123-4567</a></span>
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24"><path d="M12 22s8-7.5 8-13a8 8 0 1 0-16 0c0 5.5 8 13 8 13z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="9" r="3"/></svg>
                        <span>Mon–Fri, 10am–6pm — we usually reply within a day</span>
                    </li>
                </ul>
            </div>

            <div class="contact-form-shell">
                <form>
                    <div class="field-grid">
                        <div class="field">
                            <label for="contact-name">Name</label>
                            <input type="text" id="contact-name" name="name" placeholder="Your name" required>
                        </div>
                        <div class="field">
                            <label for="contact-email">Email</label>
                            <input type="email" id="contact-email" name="email" placeholder="you@example.com" required>
                        </div>
                        <div class="field field-full">
                            <label for="contact-subject">Subject</label>
                            <input type="text" id="contact-subject" name="subject" placeholder="What's this about?" required>
                        </div>
                        <div class="field field-full">
                            <label for="contact-message">Message</label>
                            <textarea id="contact-message" name="message" placeholder="Tell us a bit more..." required></textarea>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Send message</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<%- include('footer') %>
